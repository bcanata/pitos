DATABASE_URL=./pitos.db
ANTHROPIC_API_KEY=
AUTH_SECRET=
APP_URL=http://localhost:3000

# Email — Resend (free 3k/mo: resend.com/api-keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourteam.com

# Email — Cloudflare (requires Workers Paid $5/mo — leave blank if using Resend)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
FROM_EMAIL=

# Database — Turso (free persistent SQLite: turso.tech)
# Leave blank to use local SQLite (./pitos.db) or ephemeral /tmp on Vercel
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Demo rate limits (defaults: 20 user msgs/24h, 2000 total agent runs/24h)
# Set RATE_LIMIT_DISABLED=1 to bypass entirely (for own-instance ownership)
RATE_LIMIT_USER_DAILY=20
RATE_LIMIT_GLOBAL_DAILY=2000
RATE_LIMIT_DISABLED=
