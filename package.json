{
  "name": "pitos-app",
  "version": "0.1.2",
  "description": "FRC team workspace with magic-link auth, Slack-style channels, and Claude-powered agents. Run `npx pitos` to scaffold.",
  "keywords": [
    "frc",
    "robotics",
    "workspace",
    "claude",
    "anthropic",
    "nextjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bcanata/pitos.git"
  },
  "license": "MIT",
  "bin": {
    "pitos-app": "bin/pitos.js",
    "pitos-mcp": "bin/pitos-mcp.js"
  },
  "files": [
    "app",
    "bin",
    "cli",
    "components",
    "db",
    "drizzle",
    "lib",
    "mcp",
    "public",
    "scripts",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    ".env.example",
    "components.json",
    "drizzle.config.ts",
    "eslint.config.mjs",
    "next.config.ts",
    "next-env.d.ts",
    "postcss.config.mjs",
    "proxy.ts",
    "tsconfig.json",
    "vercel.json"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "setup": "tsx cli/index.ts",
    "mcp": "tsx mcp/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@base-ui/react": "^1.4.1",
    "@inquirer/prompts": "^8.4.2",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucia": "^3.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
